<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Robert Franklin Johnston, M.D.</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif; background: #f0ede6; padding: 20px 16px 40px; color: #1a1a18; }
.page { max-width: 940px; margin: 0 auto; background: #fff; border-radius: 12px; border: 1px solid #d8d5ce; padding: 26px 26px 30px; }
.hdr { text-align: center; margin-bottom: 16px; border-bottom: 1px solid #e5e2da; padding-bottom: 14px; }
.hdr h1 { font-size: 23px; font-weight: 600; }
.hdr .dates { font-size: 13px; color: #666; margin-top: 4px; }
.hdr .tagline { font-size: 12px; color: #888; margin-top: 5px; font-style: italic; }
.stat-row { display: flex; gap: 8px; margin-bottom: 16px; }
.stat-card { flex: 1; text-align: center; background: #f9f8f5; border: 1px solid #e5e3db; border-radius: 8px; padding: 10px 4px; }
.stat-num { font-size: 20px; font-weight: 700; }
.stat-lbl { font-size: 10px; color: #666; text-transform: uppercase; letter-spacing: 0.4px; margin-top: 2px; line-height: 1.3; }
#map { width: 100%; height: 420px; border-radius: 10px; border: 1px solid #ccc; margin-bottom: 10px; }
.legend { display: flex; flex-wrap: wrap; gap: 8px 18px; justify-content: center; margin-bottom: 16px; }
.leg-item { display: flex; align-items: center; gap: 5px; font-size: 11px; color: #555; }
.leg-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
.bottom { display: flex; gap: 16px; align-items: flex-start; margin-bottom: 16px; }
.photo-card { flex-shrink: 0; width: 190px; background: #f5f4f0; border: 1px solid #ddd; border-radius: 8px; overflow: hidden; }
.photo-card img { width: 100%; height: 220px; object-fit: cover; object-position: center top; display: block; }
.photo-caption { font-size: 10px; color: #666; padding: 7px 9px 8px; line-height: 1.45; }
.photo-caption strong { font-size: 10px; font-weight: 600; color: #1a1a18; display: block; margin-bottom: 2px; }
.life-grid { flex: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.life-card { background: #f9f8f5; border: 1px solid #e5e3db; border-radius: 7px; padding: 9px 11px; border-left: 3px solid #ccc; }
.lc-year { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 3px; }
.lc-title { font-size: 12px; font-weight: 600; color: #1a1a18; margin-bottom: 3px; line-height: 1.3; }
.lc-body { font-size: 11px; color: #555; line-height: 1.5; }
.pub-section { margin: 14px 0 0; background: #f9f8f5; border: 1px solid #e5e3db; border-radius: 8px; padding: 12px 14px; }
.pub-section h3 { font-size: 12px; font-weight: 600; color: #1a1a18; margin-bottom: 8px; }
.pub-list { display: grid; grid-template-columns: 1fr 1fr; gap: 5px 16px; }
.pub-item { font-size: 11px; color: #555; line-height: 1.4; padding: 4px 0; border-bottom: 1px solid #ece9e2; }
.pub-item a { color: #1a5fa5; text-decoration: none; }
.pub-item a:hover { text-decoration: underline; }
.pub-meta { color: #888; font-size: 10px; display: block; margin-top: 1px; }
.share-bar { display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 14px; flex-wrap: wrap; }
.share-btn { display: inline-flex; align-items: center; gap: 6px; padding: 7px 16px; border-radius: 20px; font-size: 12px; font-weight: 600; cursor: pointer; border: none; transition: opacity 0.15s; }
.share-btn:hover { opacity: 0.85; }
.copy-msg { font-size: 11px; color: #27ae60; font-weight: 600; display: none; }
.footer { text-align: center; font-size: 10px; color: #aaa; margin-top: 16px; padding-top: 10px; border-top: 1px solid #eee; }
.leaflet-popup-content-wrapper { border-radius: 8px !important; box-shadow: 0 2px 12px rgba(0,0,0,0.2) !important; }
.leaflet-popup-content { margin: 10px 14px !important; min-width: 200px; }
.pop-yr { font-size: 10px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; margin-bottom: 3px; }
.pop-title { font-size: 13px; font-weight: 700; color: #1a1a18; margin-bottom: 4px; line-height: 1.3; }
.pop-body { font-size: 11px; color: #444; line-height: 1.55; max-width: 220px; }
@media (max-width: 600px) {
  .bottom { flex-direction: column; }
  .photo-card { width: 100%; }
  .life-grid { grid-template-columns: 1fr; }
  .stat-row { flex-wrap: wrap; }
  .stat-card { min-width: 45%; }
  .pub-list { grid-template-columns: 1fr; }
}
</style>
</head>
<body>
<div class="page">
  <div class="hdr">
    <h1>Robert Franklin Johnston, M.D.</h1>
    <div class="dates">August 5, 1932 &ndash; July 31, 1982 &nbsp;&middot;&nbsp; Ann Arbor, MI &nbsp;&rarr;&nbsp; Wyncote, PA</div>
    <div class="tagline">Physician &middot; Pulmonologist &middot; Professor &middot; Father of six &middot; 60 peer-reviewed publications</div>
  </div>

  <div class="share-bar">
    <button class="share-btn" style="background:#1a1a18;color:#fff" onclick="copyLink()">&#128279; Copy link</button>
    <button class="share-btn" style="background:#2980b9;color:#fff" onclick="emailShare()">&#9993; Share via email</button>
    <button class="share-btn" style="background:#27ae60;color:#fff" onclick="downloadFile()">&#8659; Download</button>
    <span class="copy-msg" id="copy-msg">Link copied!</span>
  </div>

  <div class="stat-row">
    <div class="stat-card"><div class="stat-num" style="color:#2980b9">60</div><div class="stat-lbl">Publications</div></div>
    <div class="stat-card"><div class="stat-num" style="color:#c0392b">6</div><div class="stat-lbl">Children</div></div>
    <div class="stat-card"><div class="stat-num" style="color:#27ae60">VP</div><div class="stat-lbl">American Thoracic Society</div></div>
    <div class="stat-card"><div class="stat-num" style="color:#8e44ad">Pres.</div><div class="stat-lbl">PA Thoracic Soc. 1979&ndash;81</div></div>
    <div class="stat-card"><div class="stat-num" style="color:#e67e22">#1</div><div class="stat-lbl">Led U-M Med class 1957</div></div>
  </div>

  <div id="map"></div>

  <div class="legend">
    <div class="leg-item"><div class="leg-dot" style="background:#e67e22"></div>Early life</div>
    <div class="leg-item"><div class="leg-dot" style="background:#c0392b"></div>Wyoming summers</div>
    <div class="leg-item"><div class="leg-dot" style="background:#2980b9"></div>Education</div>
    <div class="leg-item"><div class="leg-dot" style="background:#27ae60"></div>Academic career</div>
    <div class="leg-item"><div class="leg-dot" style="background:#8e44ad"></div>Family home</div>
  </div>

  <div class="bottom">
    <div class="photo-card">
      <img src="data:image/jpeg;base64," alt="Robert Franklin Johnston, M.D.">
      <div class="photo-caption">
        <strong>Robert Franklin Johnston, M.D.</strong>
        Director of pulmonary disease, Hahnemann Medical School. Photo from his Philadelphia Inquirer obituary, August 3, 1982.
      </div>
    </div>
    <div class="life-grid">
      <div class="life-card" style="border-left-color:#e67e22">
        <div class="lc-year" style="color:#e67e22">1932</div>
        <div class="lc-title">Born in Ann Arbor, Michigan</div>
        <div class="lc-body">Born August 5, 1932 to Franklin Davis Johnston (head of U-M Cardiology) and Margaret Woodwell Johnston. Student council president and basketball team captain in high school &mdash; a leader from the start.</div>
      </div>
      <div class="life-card" style="border-left-color:#c0392b">
        <div class="lc-year" style="color:#c0392b">1949&ndash;1953</div>
        <div class="lc-title">Summers at Camp Davis &mdash; Wyoming</div>
        <div class="lc-body">As a U-M undergraduate, Robert spent summers at Camp Davis, a 120-acre field station at 6,113 ft in the Hoback River Valley near Jackson Hole &mdash; 25 miles south of Jackson, surrounded by Grand Teton National Park. The camp was originally established under his great-grandfather Clarence T. Johnston's direction in 1929.</div>
      </div>
      <div class="life-card" style="border-left-color:#2980b9">
        <div class="lc-year" style="color:#2980b9">1949&ndash;1957</div>
        <div class="lc-title">University of Michigan</div>
        <div class="lc-body">Completed undergraduate studies (1949&ndash;53) then <strong>led his class</strong> at U-M Medical School (1953&ndash;57). Member of Alpha Omega Alpha medical honors society and the Victor Vaughn Historical Society. Married Joan M. Bachmann on June 12, 1952.</div>
      </div>
      <div class="life-card" style="border-left-color:#2980b9">
        <div class="lc-year" style="color:#2980b9">1957&ndash;1967</div>
        <div class="lc-title">Medical College of Pennsylvania</div>
        <div class="lc-body">Assistant professor of medicine specializing in pulmonary disease. Named director of research and education at Henry R. Landis State Hospital, one of Pennsylvania's last sanitariums for tuberculosis treatment. Published foundational research including his landmark 1964 study on hepatic hydrothorax.</div>
      </div>
      <div class="life-card" style="border-left-color:#27ae60">
        <div class="lc-year" style="color:#27ae60">1967&ndash;1982</div>
        <div class="lc-title">Hahnemann Medical School, Philadelphia</div>
        <div class="lc-body">Director of Hahnemann's pulmonary disease division and member of the faculty. Also acting director of respiratory therapy at Jeanes Hospital, Fox Chase. Author of 60 publications. VP of the American Thoracic Society. President of the Pennsylvania Thoracic Society (1979&ndash;1981). On the editorial board of the <em>American Review of Respiratory Diseases</em>.</div>
      </div>
      <div class="life-card" style="border-left-color:#8e44ad">
        <div class="lc-year" style="color:#8e44ad">1964&ndash;1982</div>
        <div class="lc-title">Family home &mdash; Wyncote, Pennsylvania</div>
        <div class="lc-body">Settled at 209 Fernwood Ave, Wyncote, PA when daughter Laurie was 11. Robert and Joan raised six children here: Laurie (1953), Wendy (1955), Tracy (1956), Thomas (1959), Robert Jr. (1961), and Jennifer (1964). The home stayed in the Johnston family for over 50 years.</div>
      </div>
    </div>
  </div>

  <div class="pub-section">
    <h3>Selected Publications &mdash; Robert Franklin Johnston, M.D. &nbsp;<span style="font-weight:400;color:#888">(click titles to view on PubMed)</span></h3>
    <div class="pub-list">
      <div class="pub-item"><a href="https://pubmed.ncbi.nlm.nih.gov/14218925/" target="_blank" rel="noopener">Hepatic hydrothorax: studies to determine the source of the fluid and report of 13 cases</a> <span class="pub-meta">Ann Intern Med. 1964</span></div>
<div class="pub-item"><a href="https://pubmed.ncbi.nlm.nih.gov/5764771/" target="_blank" rel="noopener">Chemotherapy of pulmonary tuberculosis</a> <span class="pub-meta">Ann Intern Med. 1969</span></div>
<div class="pub-item"><a href="https://pubmed.ncbi.nlm.nih.gov/4597951/" target="_blank" rel="noopener">The impact of chemotherapy on the care of patients with tuberculosis</a> <span class="pub-meta">Am Rev Respir Dis. 1974</span></div>
<div class="pub-item"><a href="https://pubmed.ncbi.nlm.nih.gov/14255958/" target="_blank" rel="noopener">Tracheobronchiomegaly: report of 5 cases and demonstration of familial occurrence</a> <span class="pub-meta">Am Rev Respir Dis. 1965</span></div>
<div class="pub-item"><a href="https://pubmed.ncbi.nlm.nih.gov/4584271/" target="_blank" rel="noopener">Pathogenesis and treatment of respiratory failure</a> <span class="pub-meta">Ann Clin Lab Sci. 1973</span></div>
<div class="pub-item"><a href="https://pubmed.ncbi.nlm.nih.gov/4829091/" target="_blank" rel="noopener">Bronchoscopy during mechanical ventilation using the fiberscope</a> <span class="pub-meta">Chest. 1974</span></div>
<div class="pub-item"><a href="https://pubmed.ncbi.nlm.nih.gov/7330454/" target="_blank" rel="noopener">Alveolar proteinosis lung lavage using partial cardiopulmonary bypass</a> <span class="pub-meta">Thorax. 1981</span></div>
<div class="pub-item"><a href="https://pubmed.ncbi.nlm.nih.gov/5476830/" target="_blank" rel="noopener">The effect of anemia on pulmonary diffusing capacity</a> <span class="pub-meta">Am Rev Respir Dis. 1970</span></div>
<div class="pub-item"><a href="https://pubmed.ncbi.nlm.nih.gov/350061/" target="_blank" rel="noopener">Antituberculosis chemotherapy</a> <span class="pub-meta">Am Fam Physician. 1978</span></div>
<div class="pub-item"><a href="https://pubmed.ncbi.nlm.nih.gov/14020994/" target="_blank" rel="noopener">Progressive multifocal leukoencephalopathy</a> <span class="pub-meta">Arch Intern Med. 1963</span></div>
<div class="pub-item"><a href="https://pubmed.ncbi.nlm.nih.gov/1176556/" target="_blank" rel="noopener">Bronchofiberscopic examinations by pulmonary physicians: a review of 350 cases</a> <span class="pub-meta">J Am Osteopath Assoc. 1975</span></div>
<div class="pub-item"><a href="https://pubmed.ncbi.nlm.nih.gov/4596399/" target="_blank" rel="noopener">BCG vaccination in this country: Yes or No?</a> <span class="pub-meta">Am Lung Assoc Bull. 1974</span></div>

    </div>
  </div>

  <div class="footer">Ann Arbor, MI &nbsp;&middot;&nbsp; Hoback Valley, WY &nbsp;&middot;&nbsp; Philadelphia, PA &nbsp;&middot;&nbsp; Wyncote, PA</div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function() {
  var map = L.map("map", { zoomControl: true, scrollWheelZoom: false });

  // Satellite layer
  var satellite = L.tileLayer("https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}", {
    attribution: "Tiles &copy; Esri &mdash; Source: Esri, Maxar, GeoEye, USDA, USGS, AeroGRID, IGN, GIS User Community",
    maxZoom: 18
  });

  // Labels layer on top
  var labels = L.tileLayer("https://server.arcgisonline.com/ArcGIS/rest/services/Reference/World_Boundaries_and_Places/MapServer/tile/{z}/{y}/{x}", {
    maxZoom: 18, opacity: 0.8, pane: "shadowPane"
  });

  satellite.addTo(map);
  labels.addTo(map);

  function pin(color) {
    return L.divIcon({
      className: "",
      html: "<div style='width:15px;height:15px;border-radius:50%;background:" + color + ";border:2.5px solid #fff;box-shadow:0 1px 6px rgba(0,0,0,0.6);'></div>",
      iconSize: [15, 15], iconAnchor: [7, 7], popupAnchor: [0, -10]
    });
  }

  var pins = [
    { lat: 42.28, lon: -83.74, color: "#e67e22", year: "1932", title: "Born in Ann Arbor, Michigan", body: "Born August 5, 1932 to Franklin Davis Johnston (head of U-M Cardiology) and Margaret Woodwell. Student council president and basketball captain. Attended U-M 1949&ndash;1957." },
    { lat: 43.35, lon: -110.62, color: "#c0392b", year: "1949&ndash;1953", title: "Camp Davis, Hoback Valley, Wyoming", body: "Spent summers at Camp Davis, a 120-acre U-M field station at 6,113 ft, 25 miles south of Jackson Hole near the Hoback River. Originally established by his great-grandfather Clarence T. Johnston in 1929. Surrounded by Grand Teton National Park and the Greater Yellowstone Ecosystem." },
    { lat: 39.99, lon: -75.21, color: "#2980b9", year: "1957&ndash;1967", title: "Medical College of Pennsylvania, Philadelphia", body: "Assistant professor of medicine. Director of research at Henry R. Landis State Hospital, one of PA's last TB sanitariums. Published foundational 1964 study on hepatic hydrothorax cited hundreds of times in subsequent literature." },
    { lat: 39.97, lon: -75.16, color: "#27ae60", year: "1967&ndash;1982", title: "Hahnemann Medical School, Philadelphia", body: "Director of pulmonary disease division. Author of 60 publications on tuberculosis, bronchoscopy, respiratory failure, and emphysema. VP of American Thoracic Society. President of Pennsylvania Thoracic Society 1979&ndash;1981. Editorial board, American Review of Respiratory Diseases." },
    { lat: 40.09, lon: -75.15, color: "#8e44ad", year: "1964&ndash;1982", title: "Family home, Wyncote, Pennsylvania", body: "209 Fernwood Ave, Wyncote, PA &mdash; home to Robert, Joan, and their six children for nearly 20 years. Robert died here July 31, 1982, aged 49. The home remained in the Johnston family for over 50 years." }
  ];

  var allLatLons = [];
  pins.forEach(function(p) {
    var m = L.marker([p.lat, p.lon], { icon: pin(p.color) }).addTo(map);
    m.bindPopup(
      "<div class='pop-yr' style='color:" + p.color + "'>" + p.year + "</div>" +
      "<div class='pop-title'>" + p.title + "</div>" +
      "<div class='pop-body'>" + p.body + "</div>",
      { maxWidth: 280 }
    );
    allLatLons.push([p.lat, p.lon]);
  });

  // Route line
  var route = [[42.28,-83.74],[43.35,-110.62],[42.28,-83.74],[39.99,-75.21],[39.97,-75.16],[40.09,-75.15]];
  L.polyline(route, { color: "#fff", weight: 1.5, dashArray: "5,4", opacity: 0.55 }).addTo(map);

  map.fitBounds(L.latLngBounds(allLatLons).pad(0.12));
})();

function copyLink() {
  var url = window.location.href;
  function show() {
    var m = document.getElementById("copy-msg");
    m.style.display = "inline";
    setTimeout(function() { m.style.display = "none"; }, 2500);
  }
  if (navigator.clipboard) { navigator.clipboard.writeText(url).then(show).catch(function() { fallback(url, show); }); }
  else { fallback(url, show); }
}
function fallback(url, cb) {
  var ta = document.createElement("textarea");
  ta.value = url; document.body.appendChild(ta); ta.select();
  document.execCommand("copy"); document.body.removeChild(ta); cb();
}
function emailShare() {
  var s = encodeURIComponent("Robert Franklin Johnston, M.D. - A Life in Medicine");
  var b = encodeURIComponent("Sharing this biography of Robert Franklin Johnston (1932-1982), pulmonologist and professor.\n\n" + window.location.href);
  window.location.href = "mailto:?subject=" + s + "&body=" + b;
}
function downloadFile() {
  var a = document.createElement("a");
  a.href = window.location.href; a.download = "johnston_biography.html"; a.click();
}
</script>
</body>
